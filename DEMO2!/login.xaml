<Page x:Class="DEMO2_.login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DEMO2_"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="login">

    <Grid Background="white">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="430" Width="300">
            <TextBlock Text="login" FontSize="50" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="email" FontSize="30" HorizontalAlignment="Center" Margin="0,20"/>
            <TextBox Height="30" Name="emailtextbox"/>
            <TextBlock Text="password" FontSize="30" HorizontalAlignment="Center" Margin="0,20"/>
            <PasswordBox Height="30" Name="passwordtextbox"/>
            <Button Content="login" HorizontalAlignment="Center" Height="60" Width="100" FontSize="30" Margin="0,20" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>
